{
  "name": "@ubinity/node-llm",
  "version": "1.0.0",
  "description": "Universal LLM Routing Engine for Node.js",
  "author": "Ubinity DX Team <dx@ubinity.tech>",
  "license": "MPL-2.0",
  "keywords": [
    "llm",
    "ai",
    "openai",
    "gemini",
    "anthropic",
    "routing",
    "unified"
  ],
  "type": "commonjs",
