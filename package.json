    "openai": {
      "optional": true
    },
    "@google/genai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "scripts": {
    "test": "jest",
    "prepublishOnly": "npm test"
  },
  "devDependencies": {
    "jest": "^30.4.2"
